# Frontend Configuration (.env)
# Copie este arquivo para .env.local e configure os valores

# API Backend URL - Mude para seu servidor de produção
VITE_API_URL=http://localhost:3000

# Debug Mode (true/false)
VITE_DEBUG=false

# Firebase Configuration (opcional, se usar autenticação Firebase direta)
# VITE_FIREBASE_API_KEY=sua_chave_aqui
# VITE_FIREBASE_AUTH_DOMAIN=seu_projeto.firebaseapp.com
